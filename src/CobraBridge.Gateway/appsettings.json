{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // --- Strangler switch (Phase 3b) ---
  // "legacy" -> /api/accounts is served by the Bridge (COBOL via legacy-core).
  // "modern" -> /api/accounts is served by AccountsService (PostgreSQL).
  // Same JSON contract either way, so flipping this is invisible to clients.
  // Override via the AccountsSource env var. Program.cs reads this (plus
  // Services:Bridge / Services:AccountsService below) and resolves it into
  // the "accounts" cluster's destination address before YARP loads config.
  "AccountsSource": "legacy",

  "Services": {
    "Bridge": "http://localhost:5080/",
    "AccountsService": "http://localhost:5100/"
  },

  // YARP reverse proxy configuration. This is the gateway's single entry
  // point: every external client speaks to this process, which routes to
  // the internal services by path prefix.
  "ReverseProxy": {
    "Routes": {
      // /api/accounts and /api/accounts/{id} -> whichever backend
      // AccountsSource currently selects (see above). PathRemovePrefix
      // strips "/api" so the backend keeps seeing its own native /accounts
      // routes unchanged.
      "accounts-exact-route": {
        "ClusterId": "accounts",
        "Match": { "Path": "/api/accounts" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "accounts-route": {
        "ClusterId": "accounts",
        "Match": { "Path": "/api/accounts/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },

      // /api/customers and /api/customers/{id} -> CustomersService. Net-new
      // capability (no COBOL equivalent), so there's exactly one backend —
      // no Strangler switch here, unlike /api/accounts above.
      "customers-exact-route": {
        "ClusterId": "customers-svc",
        "Match": { "Path": "/api/customers" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "customers-route": {
        "ClusterId": "customers-svc",
        "Match": { "Path": "/api/customers/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      }

      // --- Phase 3d (disabled): transactions microservice ---
      // "transactions-route": {
      //   "ClusterId": "transactions-svc",
      //   "Match": { "Path": "/api/transactions/{**catch-all}" },
      //   "Transforms": [ { "PathRemovePrefix": "/api" } ]
      // }
    },
    "Clusters": {
      // Destination is overwritten at startup (see Program.cs) based on
      // AccountsSource. The value below is just the initial default before
      // that resolution runs.
      "accounts": {
        "Destinations": {
          "accounts1": { "Address": "http://localhost:5080/" }
        }
      },

      // CustomersService — single backend, no switch. docker-compose
      // overrides this via the
      // ReverseProxy__Clusters__customers-svc__Destinations__d1__Address
      // env var to reach the "customers-service" container by name.
      "customers-svc": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5110/" }
        }
      }

      // --- Phase 3d (disabled): future clusters ---
      // "transactions-svc": {
      //   "Destinations": { "d1": { "Address": "http://transactions-svc:8080/" } }
      // }
    }
  }
}
