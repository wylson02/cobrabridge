{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // YARP reverse proxy configuration. This is the gateway's single entry
  // point: every external client speaks to this process, which routes to
  // the internal services by path prefix.
  "ReverseProxy": {
    "Routes": {
      // /api/accounts and /api/accounts/{id} -> the Bridge (Phase 2, COBOL
      // account master served as JSON). PathRemovePrefix strips "/api" so
      // the Bridge keeps seeing its own native /accounts routes unchanged.
      "accounts-exact-route": {
        "ClusterId": "bridge",
        "Match": { "Path": "/api/accounts" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "accounts-route": {
        "ClusterId": "bridge",
        "Match": { "Path": "/api/accounts/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      }

      // --- Phase 3b (disabled): modern accounts microservice ---
      // "accounts-modern-route": {
      //   "ClusterId": "accounts-svc",
      //   "Match": { "Path": "/api/v2/accounts/{**catch-all}" },
      //   "Transforms": [ { "PathRemovePrefix": "/api/v2" } ]
      // },

      // --- Phase 3c (disabled): transactions microservice ---
      // "transactions-route": {
      //   "ClusterId": "transactions-svc",
      //   "Match": { "Path": "/api/transactions/{**catch-all}" },
      //   "Transforms": [ { "PathRemovePrefix": "/api" } ]
      // },

      // --- Phase 3d (disabled): customers microservice ---
      // "customers-route": {
      //   "ClusterId": "customers-svc",
      //   "Match": { "Path": "/api/customers/{**catch-all}" },
      //   "Transforms": [ { "PathRemovePrefix": "/api" } ]
      // }
    },
    "Clusters": {
      // The Bridge — defaults to localhost for `dotnet run`; docker-compose
      // overrides this via the ReverseProxy__Clusters__bridge__Destinations__bridge1__Address
      // env var to reach the "bridge" service by its container name.
      "bridge": {
        "Destinations": {
          "bridge1": { "Address": "http://localhost:5080/" }
        }
      }

      // --- Phase 3b/c/d (disabled): future clusters ---
      // "accounts-svc": {
      //   "Destinations": { "d1": { "Address": "http://accounts-svc:8080/" } }
      // },
      // "transactions-svc": {
      //   "Destinations": { "d1": { "Address": "http://transactions-svc:8080/" } }
      // },
      // "customers-svc": {
      //   "Destinations": { "d1": { "Address": "http://customers-svc:8080/" } }
      // }
    }
  }
}
