{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Dev-only default credentials for the local/demo Postgres instance.
  // Database-per-service: "cobrabridge_customers" is this service's own
  // database, separate from AccountsService's "cobrabridge_accounts", on
  // the same Postgres server. Never used outside this project's compose
  // stack; override in real deployments via ConnectionStrings__Customers.
  "ConnectionStrings": {
    "Customers": "Host=localhost;Port=5432;Database=cobrabridge_customers;Username=cobrabridge;Password=cobrabridge_dev_only_change_me"
  }
}
