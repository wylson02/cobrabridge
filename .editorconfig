root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.cs]
indent_size = 4

[*.{cbl,cpy}]
indent_size = 4

[*.{yml,yaml,json,jsx,js,ts,tsx}]
indent_size = 2

# Fixed-width data: never reformat
[*.DAT]
trim_trailing_whitespace = false
insert_final_newline = false
